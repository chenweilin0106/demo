	"Center List Template": {
		"prefix": "centerlisttemplate",
		"body": [
			"<div class=\"list\">",
			"  <div v-for=\"(item, index) in 3\" :key=\"index\" class=\"award flex-column align-center\">",
			"    <div class=\"icon position-relative\" ><PublicImg :imgName=\"'ljs_120_120.png'\" imgType=\"\" /></div>",
			"    <div class=\"text w-100 flex align-center justify-center line-height-1 text-nowrap\">{{123123}}</div>",
			"  </div>",
			"</div>",
			"",
			".list{",
			"  \\$listWidth: 494px; /*列表宽度*/",
			"  \\$itemIconSize: 128px; /*图标大小*/",
			"  \\$colNum: 3; // 列数",
			"  \\$gapNum: calc(\\$colNum * 2 + 2); /*间隔数*/",
			"  \\$gap: calc((\\$listWidth - \\$itemIconSize * \\$colNum) / \\$gapNum);",
			"  \\$itemWidth: calc(\\$itemIconSize + 2 * \\$gap); /*每个item的宽度*/",
			"  \\$textHeight: 2 * 15 + 21px; /*文本距离图标位置 文字距离图标距离 * 2 + 文本高度*/ ",
			"  // \\$listPadding: 32px \\$gap calc(32px - (51px - 25px - 15px)) \\$gap; /*顶部：距离顶部的距离 底部间距：顶部间距-(顶部间距-文字高度-文字距离图标距离)*/",
			"  \\$listPadding: 15px \\$gap 0; // 距离顶部的距离确保label展示完整",
			"  width: \\$listWidth;",
			"  height: fit-content;",
			"  min-height: calc(\\$itemIconSize + 48px); /*最小展示一行： 图标高度 + 文字高度*/",
			"  max-height: calc((\\$itemIconSize + \\$textHeight) * 3 + (\\$itemIconSize + \\$textHeight) / 6); /*最多展示三行： 图标高度 + 文字高度 +  1/6（图标高度 + 文字高度）*/",
			"  overflow-y: scroll;",
			"  overflow-x: hidden;",
			"  display: flex;",
			"  justify-content: center;",
			"  flex-wrap: wrap;",
			"  align-content: start;",
			"  padding: \\$listPadding;",
			"  .award{",
			"    \\$borderWidth: 4px; /*边框粗细*/",
			"    \\$radius: 20px; /*圆角*/",
			"    \\$borderColor: #fff; /*边框颜色*/",
			"    \\$bgc: linear-gradient(0deg, #F8BA4E, #FDE181); /*图标背景色*/",
			"    \\$fontSize: 26px; /*文本字体大小*/",
			"    \\$color: #9C4D01; /*文本字体颜色*/",
			"    width: \\$itemWidth;",
			"    .icon{",
			"      width: \\$itemIconSize;",
			"      height: \\$itemIconSize;",
			"      border-radius: \\$radius + \\$borderWidth;",
			"      border: \\$borderWidth solid \\$borderColor;",
			"      background: \\$bgc;",
			"    }",
			"    .text{",
			"      width: \\$itemIconSize;",
			"      height: \\$textHeight;",
			"      font-size: \\$fontSize;",
			"      color: \\$color;",
			"    }",
			"  }",
			"}"
		],
